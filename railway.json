{
  "$schema": "https://railway.app/railway.schema.json",
  "build": {
    "builder": "DOCKERFILE",
    "dockerfilePath": "docker/DockerFile"
  },
  "deploy": {
    "startCommand": "uv run python -m valuecell.server.main",
    "healthcheckPath": "/health",
    "restartPolicyType": "ON_FAILURE"
  }
}
